{
  "name": "Password Manager Codespace",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/Password/password-manager",
  "forwardPorts": [8080, 3306],
  "portsAttributes": {
    "8080": {
      "label": "Password Manager App",
      "onAutoForward": "openBrowser"
    },
    "3306": {
      "label": "MySQL"
    }
  }
}